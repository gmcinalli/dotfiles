# Aliases

alias dotfiles="code ~/.dotfiles"
alias aliases="code ~/.dotfiles/sheldon/plugins/aliases-macos/aliases-macos.zsh"

alias ls="exa --icons --group --group-directories-first"
alias ll="exa --icons --group --group-directories-first --long"
alias lla="exa --icons --group --group-directories-first --long --all"

alias python="/opt/homebrew/opt/python@3.9/libexec/bin/python"